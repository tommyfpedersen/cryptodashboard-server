<div class="card" id="stats-pbaas-max-supply-card">
    <img width="16px" src="/img/stats.png" />
    <button class="hide-button">x</button>
    <div class="card-content">
        <div class="card-title">PBaaS Max Supply</div>
        {{!-- {{#if vrscOnline}} --}}
        {{#each maxSupplyArray}}
        <div class="card-row-wrapper">
            <div class="card-row-item">{{{this.blockchain}}}</div>
            <div class="card-row-item">
                 {{{ this.maxSupply }}}
            </div>
        </div>
        {{/each}}

    </div>
</div>